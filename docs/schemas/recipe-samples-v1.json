      { "name": "盐", "name_en": "salt", "quantity": 5, "unit": "g",
        "role": "seasoning" },
      { "name": "生抽", "name_en": "light soy sauce", "quantity": 30, "unit": "ml",
        "role": "seasoning" },
      { "name": "花生油", "name_en": "peanut oil", "quantity": 15, "unit": "ml",
        "role": "fat" },
      { "name": "香油", "name_en": "sesame oil", "quantity": 5, "unit": "ml",
        "role": "fat" }
