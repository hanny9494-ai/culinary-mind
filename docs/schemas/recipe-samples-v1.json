      {
        "order": 3, "action": "drain",
        "targets": ["基围虾"],
        "target_state": "沥干，不带多余水",
        "params": { "time_s": 30 }
      },
      {
        "order": 4, "action": "plate",
        "targets": ["基围虾"],
        "note": "摆盘，淋热油激香"
      },
      {
        "order": 5, "action": "season",
        "targets": ["生抽", "花生油", "香油"],
        "target_state": "酱汁热烫冒烟",
        "params": { "temp_c": 180, "time_s": 10 },
        "note": "热油激沙姜蒜末，增加香气层次"
      }
    ],
